# LLM provider — "ollama" (local, free), "anthropic", or "gemini"
LLM_PROVIDER=ollama

# Ollama (used when LLM_PROVIDER=ollama — no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:0.8b

# Anthropic (used when LLM_PROVIDER=anthropic)
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini (used when LLM_PROVIDER=gemini)
# Get a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Supabase — use the service role key (not the anon/publishable key)
# Found at: Supabase dashboard → Project Settings → API → service_role
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Postiz (self-hosted)
POSTIZ_BASE_URL=http://localhost:3000
POSTIZ_API_KEY=

# n8n (self-hosted)
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
